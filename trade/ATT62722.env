# Polymarket 套利系统 — 环境变量模板
# 复制此文件为 .env，填入真实值，不要提交 .env 到版本控制

# 钱包签名模式：
# 0 = EOA
# 1 = POLY_PROXY（Polymarket 官网 Google / 邮箱钱包默认建议显式写这个）
# 2 = GNOSIS_SAFE
# 如果你是通过 Polymarket 官网的 Google / 邮箱方式创建的钱包，建议明确设置为 1，
# 不要依赖自动识别，避免 SELL 阶段出现 allowance / 钱包模式误判问题。
POLY_SIGNATURE_TYPE=1

# ── Polymarket 钱包 ──────────────────────────────────────────
# 用于 EIP-712 订单签名的钱包私钥（0x 开头）
POLY_PRIVATE_KEY=0xe9d7703ca0a93650d2b7b89946af1798483b81976dd1d1e682a9f7537145d156
POLY_FUNDER_ADDRESS=0xD3Ea29ef3fbeFFCbc6Ea9D24B914864345b5f50b

# ── Polymarket CLOB API 凭证（Level 2 Auth）───────────────────
# 在 https://polymarket.com 账户设置页创建 API Key
POLY_API_KEY=827169fb-5b37-e5ff-2fda-0fb3800d6d55
POLY_API_SECRET=RfTpYLV0xAaXDwQA5OX9bOgNc0u83GwQDTm8yIx6Q-k=
POLY_API_PASSPHRASE=6c91c1a1fdf6743d2caec0704d5ec7d7a393e8a2100e2d19162522463311a65f
