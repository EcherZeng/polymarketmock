# Trade service environment variables
# Copy this to .env and fill in your credentials

# ── Polymarket Wallet (CRITICAL: signature_type=1 for Google/Email wallets) ──
TRADE_POLY_PRIVATE_KEY=0x...
TRADE_POLY_FUNDER_ADDRESS=0x...
TRADE_POLY_SIGNATURE_TYPE=1
TRADE_POLY_API_KEY=
TRADE_POLY_API_SECRET=
TRADE_POLY_API_PASSPHRASE=

# ── Service ──────────────────────────────────────────────────────────────────
TRADE_PORT=8073
TRADE_LOG_LEVEL=INFO

# ── API Authentication (empty = no auth, for dev only) ───────────────────────
TRADE_API_KEY=

# ── Execution mode: "real" = live Polymarket, "mock" = simulated fills ───────
TRADE_EXECUTOR_MODE=mock

# ── Initial balance (for PnL tracking; 0 = auto-detect from API in real mode)
TRADE_INITIAL_BALANCE=0
